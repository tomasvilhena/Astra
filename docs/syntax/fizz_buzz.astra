entry "fizz_buzz";



fn fizz_buzz(): void
{
  let value: number = read("Insert a number: ").to_number();
  repeat value as i
  {
    if ((i + 1) % 3 == 0 && (i + 1) % 5 == 0)
    {
      print("FizzBuzz ");
      continue;
    } else if ((i + 1) % 3 == 0)
    {
      print("Fizz ");
      continue;
    } else if ((i + 1) % 5 == 0)
    {
      print("Buzz ");
      continue;
    }

    print("@ ", (i + 1));
  }
}
